# Exim: fork-per-connection SMTP MTA. The listener parent accepts on
# port 25 (we move it to 2525 to avoid privileged-port issues), forks a
# child per TCP connection, and the child runs the SMTP session in a
# single process. The fork side is identical to what bftpd does, which
# already passes. Bridge state survives fork because kernel fds are
# inherited and the bridge's per-fd table is in the forked child's
# memory.
#
# What this adds to the suite: SMTP, a protocol shape we don't yet
# cover. EHLO returns a multi-line response (250-…/250 …) so it
# exercises the bridge-and-library path for sustained server-to-client
# bytes more than a single-line FTP response does.
#
# Build with: docker build -f test/integration/docker/exim/Dockerfile \
#                          -t netfuzzlib-test-exim .

FROM netfuzzlib-base

# exim4-daemon-light is the small variant. No DKIM/PostgreSQL/etc.
# Plenty for an SMTP smoke test.
RUN apt-get update \
    && DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        exim4-daemon-light \
        netcat-openbsd \
    && rm -rf /var/lib/apt/lists/*

# `update-exim4.conf` materialises /var/lib/exim4/config.autogenerated
# from the template + Debian update-exim4.conf.conf settings. Without
# that, exim4 -bV works but `exim4 -bd` aborts with "main config
# file <path>: cannot read".
RUN update-exim4.conf

COPY test/integration/docker/exim/run.sh /opt/nfl/targets/exim/run.sh
RUN chmod +x /opt/nfl/targets/exim/run.sh

ENV NFL_TARGET_NAME=exim \
    NFL_TARGET_RUN_SH=/opt/nfl/targets/exim/run.sh

ENTRYPOINT ["/opt/nfl/bin/nfl-entrypoint"]
CMD ["test"]
